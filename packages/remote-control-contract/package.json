{
  "name": "@drawdb-mcp/remote-control-contract",
  "version": "0.1.0",
  "private": true,
  "description": "Shared ORPC contract for the DrawDB remote-control WebSocket protocol (backend server -> GUI client). Defines the flat clientContract of the 28 wire commands plus the entity zod schemas both sides agree on.",
  "type": "module",
  "tshy": {
    "selfLink": false,
    "exports": {
      ".": "./src/index.ts"
    },
    "project": "./tsconfig.build.json"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/commonjs/index.d.ts",
        "default": "./dist/commonjs/index.js"
      }
    }
  },
  "main": "./dist/commonjs/index.js",
  "types": "./dist/commonjs/index.d.ts",
  "module": "./dist/esm/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tshy",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo .tshy .tshy-build *.tsbuildinfo"
  },
  "dependencies": {
    "@orpc/contract": "1.14.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "tshy": "4.1.3",
    "typescript": "^6.0.3"
  }
}
