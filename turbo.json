{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "clean": {
      "cache": false
    },
    "type-check": {},
    "test": {
      "cache": false,
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**/*.tsx",
        "src/**/*.ts",
        "test/**/*.ts",
        "test/**/*.tsx",
        "specs/**/*.ts",
        "helpers/**/*.ts",
        "setup/**/*.ts",
        "fixtures/**"
      ],
      "passThroughEnv": ["UPDATE_FIXTURES", "CI", "DRAWDB_E2E_IMAGE"]
    },
    "test:ci": {
      "cache": false,
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**/*.tsx",
        "src/**/*.ts",
        "test/**/*.ts",
        "test/**/*.tsx",
        "specs/**/*.ts",
        "helpers/**/*.ts",
        "setup/**/*.ts",
        "fixtures/**"
      ],
      "passThroughEnv": ["UPDATE_FIXTURES", "CI", "DRAWDB_E2E_IMAGE"]
    }
  }
}
